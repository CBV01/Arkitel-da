[Unit]
Description=ArkiTel FastAPI Backend
After=network.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/arkitel-backend/backend
Environment=PATH=/home/ubuntu/arkitel-backend/.venv/bin
ExecStart=/home/ubuntu/arkitel-backend/.venv/bin/python -m uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target